{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "description": "Default build using Ninja with C++26",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "26",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "LIB_NET_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "description": "Release build using Ninja",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "clang",
      "description": "Build with Clang-18 and Ninja",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++-18",
        "CMAKE_C_COMPILER": "clang-18"
      }
    },
    {
      "name": "clang-release",
      "description": "Release build with Clang-18",
      "inherits": "clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "clang",
      "configurePreset": "clang"
    },
    {
      "name": "clang-release",
      "configurePreset": "clang-release"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": "verbose"
      }
    }
  ]
}
